Bootstrap: docker
From: ubuntu:18.04

%labels
    Maintainer "Litian"
    Project "Deep F-Formation"
    Purpose "Containerized Mingling benchmark environments"
    Base "ubuntu:18.04"
    Python "3.7.1"
    PyTorch "1.10.1"
    Environment "py371"
    DANTEEnvironment "dante_tf1"
    DANTETensorFlow "tensorflow-gpu 1.14.0"
    DANTEKeras "Keras 2.2.2"
    Version "v_yaml_only"
    BuildDate "2026-03-17"

%post
    set -ex
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/opt/conda/bin:$PATH
    export CONDA_ENV_NAME=py371

    apt-get update && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        wget \
        git \
        vim \
        build-essential \
        pkg-config \
        cmake \
        ffmpeg \
        libatlas3-base \
        libblas3 \
        liblapack3 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libgomp1 \
        && rm -rf /var/lib/apt/lists/*

    wget -q https://repo.anaconda.com/miniconda/Miniconda3-py37_4.9.2-Linux-x86_64.sh -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm -f /tmp/miniconda.sh

    conda config --system --set auto_update_conda false
    conda config --system --add channels conda-forge
    conda config --system --add channels plotly
    conda config --system --add channels anaconda
    conda config --system --add channels pytorch
    conda config --system --add channels defaults
    conda config --system --set channel_priority flexible
    python --version
    python -m pip --version

    cat > /tmp/environment.yml <<'EOF'
name: py371
channels:
  - conda-forge
  - plotly
  - anaconda
  - pytorch
  - defaults
dependencies:
  - backcall=0.2.0
  - blas=1.0
  - bottleneck=1.3.2
  - brotli=1.0.9
  - brotlipy=0.7.0
  - bzip2=1.0.8
  - ca-certificates=2021.10.26
  - certifi=2021.10.8
  - cffi=1.15.0
  - charset-normalizer=2.0.4
  - cloudpickle=2.0.0
  - colorama=0.4.4
  - cryptography=36.0.0
  - cycler=0.11.0
  - decorator=5.1.0
  - ffmpeg=4.3
  - fonttools=4.25.0
  - freetype=2.11.0
  - gettext=0.21.0
  - giflib=5.2.1
  - gmp=6.2.1
  - gnutls=3.6.15
  - icu=58.2
  - idna=3.3
  - intel-openmp=2021.4.0
  - ipython=7.29.0
  - jedi=0.18.0
  - joblib=0.17.0
  - jpeg=9d
  - kiwisolver=1.3.1
  - lame=3.100
  - lcms2=2.12
  - libgcc-ng
  - libgfortran-ng
  - libiconv=1.16
  - libidn2=2.3.2
  - libllvm11=11.1.0
  - libpng=1.6.37
  - libstdcxx-ng
  - libtasn1=4.16.0
  - libtiff=4.2.0
  - libunistring=0.9.10
  - libuv=1.40.0
  - libwebp=1.2.0
  - libwebp-base=1.2.0
  - libxml2=2.9.12
  - llvmlite=0.37.0
  - lz4-c=1.9.3
  - matplotlib=3.5.0
  - matplotlib-base=3.5.0
  - matplotlib-inline=0.1.2
  - mkl=2021.4.0
  - mkl-service=2.4.0
  - mkl_fft=1.3.1
  - mkl_random=1.2.2
  - munkres=1.1.4
  - ncurses=6.3
  - nettle=3.7.3
  - nltk=3.6.5
  - numba=0.54.1
  - numexpr=2.8.1
  - numpy=1.20.3
  - numpy-base=1.20.3
  - olefile=0.46
  - openh264=2.1.1
  - openssl=1.1.1m
  - packaging=21.3
  - pandas=1.3.5
  - parso=0.8.3
  - pexpect=4.8.0
  - pickleshare=0.7.5
  - pillow=8.4.0
  - pip=21.2.2
  - plotly=5.6.0
  - prompt-toolkit=3.0.20
  - ptyprocess=0.7.0
  - pycparser=2.21
  - pygments=2.10.0
  - pynndescent=0.5.6
  - pyopenssl=21.0.0
  - pyparsing=3.0.4
  - pysocks=1.7.1
  - python=3.7.1
  - python-dateutil=2.8.2
  - python_abi=3.7
  - pytorch=1.10.1
  - pytz=2021.3
  - readline=7.0
  - regex=2021.11.2
  - requests=2.27.1
  - scikit-learn=0.23.2
  - scipy=1.7.3
  - seaborn=0.11.2
  - setuptools=58.0.4
  - shap=0.39.0
  - six=1.16.0
  - slicer=0.0.7
  - sqlite=3.33.0
  - tbb=2021.4.0
  - tenacity=8.0.1
  - threadpoolctl=2.1.0
  - tk=8.6.11
  - torchaudio=0.10.1
  - torchvision=0.11.2
  - tornado=6.1
  - tqdm=4.62.3
  - traitlets=5.1.1
  - typing_extensions=3.10.0.2
  - umap-learn=0.5.2
  - urllib3=1.26.7
  - wcwidth=0.2.5
  - wheel=0.37.1
  - xz=5.2.5
  - zlib=1.2.11
  - zstd=1.4.9
  - pip:
    # macOS-only or non-portable entries from the source YAML were intentionally omitted:
    # appnope, libcxx, libgfortran==3.0.1 (pip), and the original prefix path.
    - anyio==3.5.0
    - asgiref==3.4.1
    - click==8.0.3
    - fastapi==0.71.0
    - gower==0.0.5
    - h11==0.12.0
    - importlib-metadata==4.10.0
    - kmodes==0.11.1
    - pydantic==1.9.0
    - scikit-learn-extra==0.2.0
    - sniffio==1.2.0
    - starlette==0.17.1
    - uvicorn==0.17.0
    - zipp==3.7.0
EOF

    conda env create -f /tmp/environment.yml
    rm -f /tmp/environment.yml

    python - << 'PY'
import sys
print("base_python:", sys.version)
PY

    /opt/conda/envs/${CONDA_ENV_NAME}/bin/python - << 'PY'
import sys
import numpy, scipy, matplotlib, sklearn, pandas, torch

print("env_python:", sys.version)
print("numpy:", numpy.__version__)
print("scipy:", scipy.__version__)
print("matplotlib:", matplotlib.__version__)
print("sklearn:", sklearn.__version__)
print("pandas:", pandas.__version__)
print("torch:", torch.__version__)
print("cuda_available:", torch.cuda.is_available())
PY

    # -------------------------------------------------------------------------
    # DANTE legacy pipeline dependencies.
    #
    # Keep these in a separate conda environment so the original GraphFF/LSTM
    # PyTorch stack above remains unchanged.  DANTE-master is a TensorFlow 1.x
    # + standalone Keras codebase.  Its requirements.txt lists both
    # tensorflow==1.14.0 and tensorflow-gpu==1.14.0; installing both is
    # unnecessary and can create duplicate packages, so this env installs
    # tensorflow-gpu only, which still provides the importable `tensorflow`
    # module.  CUDA 10.0 and cuDNN 7 are included because TF 1.14 GPU wheels
    # were built against that runtime.  Keep the conda solve deliberately
    # small: older scientific Python pins are installed from pip wheels below
    # to avoid high-memory conda solving during Apptainer builds.
    # -------------------------------------------------------------------------
    export DANTE_ENV_NAME=dante_tf1
    conda create -y -n ${DANTE_ENV_NAME} \
        --override-channels \
        -c defaults \
        python=3.7.1 \
        pip=21.2.2 \
        cudatoolkit=10.0 \
        cudnn=7.6.5

    # Use the legacy resolver to honor DANTE's old standalone Keras pin.  Newer
    # pip resolvers reject the historic metadata conflict between Keras 2.2.2
    # and TensorFlow 1.14's keras-applications / keras-preprocessing bounds,
    # even though this is the stack DANTE was written against.
    /opt/conda/envs/${DANTE_ENV_NAME}/bin/pip install --no-cache-dir --use-deprecated=legacy-resolver \
        numpy==1.15.4 \
        scipy==1.1.0 \
        matplotlib==3.1.1 \
        scikit-learn==0.21.3 \
        h5py==2.10.0 \
        PyYAML==5.4.1 \
        Keras==2.2.2 \
        tensorflow-gpu==1.14.0 \
        protobuf==3.20.3 \
        gast==0.2.2 \
        tensorboard==1.14.0 \
        tensorflow-estimator==1.14.0

    /opt/conda/envs/${DANTE_ENV_NAME}/bin/python - << 'PY'
import sys
import numpy, scipy, matplotlib, sklearn
import tensorflow as tf
import keras

print("dante_env_python:", sys.version)
print("dante_numpy:", numpy.__version__)
print("dante_scipy:", scipy.__version__)
print("dante_matplotlib:", matplotlib.__version__)
print("dante_sklearn:", sklearn.__version__)
print("dante_tensorflow:", tf.__version__)
print("dante_keras:", keras.__version__)
PY

%environment
    export CONDA_ENV_NAME="py371"
    export DANTE_ENV_NAME="dante_tf1"
    export DANTE_PYTHON_BIN="/opt/conda/envs/${DANTE_ENV_NAME}/bin/python"
    export PATH="/opt/conda/envs/${CONDA_ENV_NAME}/bin:/opt/conda/bin:${PATH}"
    export PYTHONUNBUFFERED=1
    export OMP_NUM_THREADS=${OMP_NUM_THREADS:-8}
    export CONDA_DEFAULT_ENV=${CONDA_ENV_NAME}

%runscript
    export CONDA_ENV_NAME="${CONDA_ENV_NAME:-py371}"
    export PATH="/opt/conda/envs/${CONDA_ENV_NAME}/bin:/opt/conda/bin:${PATH}"
    exec "$@"
