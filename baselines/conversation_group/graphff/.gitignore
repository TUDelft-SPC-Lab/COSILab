# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# JetBrains IDE
.idea/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# Local editor / transfer config
sftp-config.json

# Local Apptainer image outputs. Recipes under apptainer/*.def are tracked so
# the HPC environment is reproducible; generated SIF images stay out of Git.
*.sif

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Runtime/cache directories
_cache/
.cache/
.codex
.codex/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs and generated outputs
logs/*
!logs/.gitkeep
output/
dynamic_scenes_mat
dynamic_scenes_dante_mat
dynamic_scenes_mat/
dynamic_scenes_dante_mat/
backup_scene_dict_cam6/

# 4TU upload package and local Mingling data stay outside the code repository.
benchmark_upload_selected_cams/
data/mingling1/
data/mingling2/
data/group_annotations/raws/
data/vitpose_dataframe/

# Datasets and local experiment artifacts
data/**/*.txt
data/**/*.pkl
data/**/*.pk
data/**/*.pickle
DANTE-master/datasets/*/fold_*/
DANTE-master/datasets/*/coordinates.txt
DANTE-master/datasets/*/affinities.txt
DANTE-master/datasets/*/timechanges.txt
DANTE-master/datasets/*/GT.csv
DANTE-master/datasets/*/scene_continuity.csv
DANTE-master/datasets/*/DS_utils/*.csv
DANTE-master/datasets/*/DS_utils/*.txt
DANTE-master/datasets/*/*/fold_*/
DANTE-master/datasets/*/*/coordinates.txt
DANTE-master/datasets/*/*/affinities.txt
DANTE-master/datasets/*/*/timechanges.txt
DANTE-master/datasets/*/*/DS_utils/*.csv
DANTE-master/datasets/*/*/DS_utils/*.txt
DANTE-master/deep_fformation/models/**
!DANTE-master/deep_fformation/models/
!DANTE-master/deep_fformation/models/**/
dominant-set/*.mat
*.mat
*.xlsx
*.xls
*.csv

# Pickled/generated intermediate data
*.pkl
*.pk
*.pickle

# Model checkpoints / trained weights
/models/
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.onnx

# Generated plots and media outputs
*.png
*.jpg
*.jpeg
*.gif
